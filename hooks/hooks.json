{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${CLAUDE_PLUGIN_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\"; bash \"$ROOT/skills/vignette-catalog-compose-notebook/scripts/red-team-on-stop.sh\" 2>/dev/null || true",
            "timeout": 20,
            "statusMessage": "Red-teaming changed notebooks..."
          }
        ]
      }
    ]
  }
}
